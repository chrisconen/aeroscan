---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactCTA from '@/components/home/ContactCTA.astro';
---

<BaseLayout
  title="Épületfelmérés - Drónos épületfelmérés"
  description="Professzionális drónos épületfelmérés Győrben és környékén. 4K felbontású felvételek, állapotfelmérés, hőképek. Ingatlanfelmérés drónnal."
>
  <!-- Hero -->
  <section class="bg-primary py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 text-white">
      <h1 class="font-heading text-4xl md:text-5xl font-bold leading-tight mb-4">
        Épületek felmérése
      </h1>
      <p class="text-xl text-gray-200 mb-4">Precíz drónos épületfelmérések szakértőktől</p>
      <p class="text-gray-300 mb-6 max-w-2xl">
        Az AeroScan-nál a dróntechnológia legmodernebb vívmányait ötvöztük a mérnöki pontossággal,
        hogy ügyfeleink számára megbízható, részletes és gyors felméréseket biztosítsunk.
      </p>
      <a href="/kapcsolat" class="inline-block bg-accent hover:bg-accent-dark text-white font-semibold py-3 px-8 rounded-lg transition-colors">
        Árajánlat kérés
      </a>
    </div>
  </section>

  <!-- Szolgáltatási területek -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Szolgáltatási területeink
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '🏠', title: 'Lakóépületek', desc: 'Társasházak, családi házak, lakóparkok légi felmérése.' },
          { icon: '🏭', title: 'Ipari létesítmények', desc: 'Gyárepületek, raktárak, logisztikai központok felmérése.' },
          { icon: '🏗️', title: 'Építkezések', desc: 'Folyamatkövetés és dokumentáció építkezési projekteknél.' },
          { icon: '🔧', title: 'Tetővizsgálat', desc: 'Nehezen hozzáférhető tetők állapotfelmérése drónnal.' },
          { icon: '🏛️', title: 'Műemlékek', desc: 'Történelmi épületek, műemlékek, templomok dokumentálása.' },
          { icon: '🌉', title: 'Infrastruktúra', desc: 'Hidak, utak, napelempárkok állapotfelmérése.' },
        ].map((item) => (
          <div class="bg-surface rounded-2xl p-6 hover:bg-white hover:shadow-lg transition-all duration-300">
            <div class="text-3xl mb-3" aria-hidden="true">{item.icon}</div>
            <h3 class="font-heading font-bold text-lg text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-text-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technológia -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-4">
        Technológiánk
      </h2>
      <p class="text-text-light text-lg text-center mb-12 max-w-2xl mx-auto">
        Csúcskategóriás drónok és adatfeldolgozási megoldások a maximális pontosságért.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          { title: 'Professzionális drónok', desc: 'Modern, ipari kategóriás DJI drónjaink akár 20 MP-es felbontású fényképezéssel és 4K videózással készítik a részletes adatokat.' },
          { title: 'RTK technológia', desc: 'Centiméteres pontosságot biztosító műholdas helymeghatározás, amely elengedhetetlen az épület- és infrastruktúrafelmérések megbízhatóságához.' },
          { title: 'Speciális szoftverek', desc: 'Fotogrammetriai technológiák, 3D modellezés és ortofotó térképek a legprecízebb eredményekért.' },
          { title: 'Adatbiztonság', desc: 'Minden adatot biztonságosan kezelünk és részletes, könnyen értelmezhető formátumban adjuk át.' },
        ].map((item) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm">
            <h3 class="font-heading font-bold text-lg text-primary mb-2">{item.title}</h3>
            <p class="text-text-light text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Miért válasszon minket -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Miért válasszon minket?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Pontosság', desc: 'Centiméteres pontosságú légi felméréseink segítik a pontos tervezést, dokumentációt és döntéshozatalt.' },
          { title: 'Egyedi megoldások', desc: 'Minden projektet az ügyfél egyedi igényeihez igazítunk, legyen szó kis vagy nagy volumenű feladatról.' },
          { title: 'Gyors kivitelezés', desc: 'Tudjuk, hogy az idő pénz — ezért gyors adatgyűjtést és feldolgozást biztosítunk, akár szoros ütemterv mellett is.' },
          { title: 'Innovatív technológia', desc: 'Modern eszközparkkal dolgozunk, és rendszeresen fejlesztjük tudásunkat a legjobb szolgáltatás érdekében.' },
          { title: 'Biztonságos', desc: 'A drónos technológia minimalizálja az emberi kockázatot és biztonságos elemzést tesz lehetővé.' },
          { title: 'Megbízhatóság', desc: 'Számunkra az elégedett ügyfél a legfontosabb referencia. Korrekt kommunikáció és tisztességes hozzáállás.' },
        ].map((item) => (
          <div class="text-center p-6 rounded-2xl bg-surface">
            <h3 class="font-heading font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-text-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfólió -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Projektjeinkből
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { img: '/images/drón_épületfelmérés_állapotfelmérés.webp', title: 'Homlokzat és tető felmérés', desc: '5 emeletes társasház teljes körű homlokzati és tetőszerkezeti vizsgálata, ortofotó térképpel és 3D modellezéssel.' },
          { img: '/images/drón-épületfelmérés_1.png', title: 'Ipari létesítmény felmérés', desc: 'Ipari létesítmény légi felmérése szerkezeti hibák azonosítására, rendszeres karbantartási és fejlesztési terv támogatására.' },
          { img: '/images/drón-épületfelmérés_2.png', title: 'Építkezési terület felmérés', desc: 'Nagy volumenű lakópark építésének rendszeres drónos dokumentációja és helyszíni állapotjelentések készítése.' },
          { img: '/images/drón-épületfelmérés_3.png', title: 'Napelempárk felmérése', desc: 'Több hektáros naperőmű területének felmérése és hibák lokalizálása hőkamerás technológiával.' },
          { img: '/images/drón_felmérés_állapotelemzés.avif', title: 'Műemlék épület felmérése', desc: 'Történelmi jelentőségű épület részletes légi feltérképezése és 3D modellezése a megőrzési projekthez.' },
        ].map((item) => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow group">
            <div class="aspect-video overflow-hidden">
              <img src={item.img} alt={item.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="font-heading font-bold text-primary mb-2">{item.title}</h3>
              <p class="text-sm text-text-light">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
