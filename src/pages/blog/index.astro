---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(posts.flatMap((p) => p.data.categories || [p.data.category]))];
---

<BaseLayout
  title="Blog"
  description="Drónos felmérések, innovatív technológiák, ipari alkalmazások - olvasson szakmai cikkeinket az AeroScan blogjában."
>
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-primary mb-4">Blog</h1>
        <p class="text-text-light text-lg max-w-2xl mx-auto">
          Szakmai cikkek drónos felmérésekről, innovatív technológiákról és ipari alkalmazásokról.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Posts -->
        <div class="lg:col-span-2 space-y-8">
          {posts.map((post) => (
            <article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow border border-gray-100">
              <a href={`/blog/${post.id}`} class="flex flex-col sm:flex-row">
                <div class="sm:w-1/3 aspect-video sm:aspect-auto overflow-hidden">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <div class="flex-1 p-5">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">
                      {post.data.category}
                    </span>
                    <time class="text-xs text-text-light" datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </div>
                  <h2 class="font-heading font-bold text-lg text-primary group-hover:text-accent transition-colors mb-2 line-clamp-2">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-text-light line-clamp-2">
                    {post.data.description}
                  </p>
                </div>
              </a>
            </article>
          ))}
        </div>

        <!-- Sidebar -->
        <aside class="space-y-8">
          <!-- Categories -->
          <div class="bg-surface rounded-2xl p-6">
            <h3 class="font-heading font-bold text-lg text-primary mb-4">Kategóriák</h3>
            <ul class="space-y-2">
              {categories.map((cat) => (
                <li>
                  <span class="text-sm text-text-light hover:text-primary transition-colors cursor-default">
                    {cat}
                  </span>
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA -->
          <div class="bg-primary rounded-2xl p-6 text-white text-center">
            <h3 class="font-heading font-bold text-lg mb-2">Kérjen árajánlatot!</h3>
            <p class="text-sm text-gray-300 mb-4">
              Professzionális drónos felmérés az Ön igényeire szabva.
            </p>
            <a
              href="/kapcsolat"
              class="inline-block bg-accent hover:bg-accent-dark text-white font-semibold py-2 px-6 rounded-lg transition-colors"
            >
              Kapcsolat
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
