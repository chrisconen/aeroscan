---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactCTA from '@/components/home/ContactCTA.astro';
---

<BaseLayout
  title="Keresés & Mentés"
  description="Drónos keresés és mentés - eltűnt személy, elveszett háziállat felkutatása. Gyors bevetés, éjszakai keresés, élő közvetítés. Győr és 100km környéke."
>
  <!-- Hero -->
  <section class="bg-primary py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 text-white">
      <h1 class="font-heading text-4xl md:text-5xl font-bold leading-tight mb-4">
        Drónos keresés & mentés
      </h1>
      <p class="text-xl text-accent font-semibold mb-4">
        Eltűnt személy? Elveszett háziállat? Ne pazarolj időt — indítsd be a drónt!
      </p>
      <p class="text-gray-300 mb-6 max-w-2xl">
        Modern technológiánkkal, tapasztalt pilótáinkkal és valós idejű légi felderítővel
        támogatjuk a gyors felderítést és a keresett személy vagy háziállat megtalálását.
      </p>
      <a href="tel:+36305696550" class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg transition-colors text-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        +36 30 569 6550
      </a>
    </div>
  </section>

  <!-- Hogyan segít -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-4">
        Hogyan segít a drónos keresés & mentés?
      </h2>
      <p class="text-text-light text-lg text-center mb-12 max-w-3xl mx-auto">
        A drón gyorsan lefedi azokat a területeket is, amelyekhez gyalogosan nehezen, vagy csak órák
        alatt lehetne eljutni — így lerövidíti a keresési időt, és növeli a megtalálás esélyét.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {[
          'Eltűnt személyek — idősek, túrázók, gyerekek',
          'Elkóborolt háziállatok — kutya, cica, haszonállatok',
          'Balesetben eltűnt vagy eltévedt személyek',
          'Elzárt, veszélyes vagy nehezen bejárható területek',
        ].map((item) => (
          <div class="flex items-start gap-3 p-4 bg-surface rounded-xl">
            <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-text">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technikai előnyök -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Technikai előnyeink
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '📷', title: 'Nagy felbontású kamera', desc: 'Éles képek, élő videó a keresési pontról.' },
          { icon: '🔦', title: 'Reflektor', desc: 'Esti vagy sötétben végzett keresésekhez.' },
          { icon: '🔊', title: 'Hangszóró', desc: 'Hívószavak, utasítások a megtalált személyhez/állathoz.' },
          { icon: '📍', title: 'GPS koordináta', desc: 'A megtalált célpontról azonnal pontos helyet adunk.' },
          { icon: '📡', title: 'Valós idejű képátvitel', desc: 'A mentésirányító, családtagok vagy hatóság is követheti.' },
          { icon: '🌡️', title: 'Hőkamera', desc: 'Személyek és állatok észlelése alacsony látási viszonyok között.' },
        ].map((item) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm">
            <div class="text-3xl mb-3" aria-hidden="true">{item.icon}</div>
            <h3 class="font-heading font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-text-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hogyan működik -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Hogyan működik?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { step: '1', title: 'Kapcsolatfelvétel', desc: 'Elérsz minket telefonon vagy online űrlapon.' },
          { step: '2', title: 'Gyors egyeztetés', desc: 'Megadod az eltűnés körülményeit, a helyszínt és időpontot.' },
          { step: '3', title: 'Drón bevetése', desc: '15-30 percen belül már a levegőben vagyunk (Győr és környékén).' },
          { step: '4', title: 'Élő támogatás', desc: 'Helymeghatározás, dokumentálás és mentési támogatás valós időben.' },
        ].map((item) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-4 bg-accent text-white rounded-full flex items-center justify-center font-heading text-xl font-bold">
              {item.step}
            </div>
            <h3 class="font-heading font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-text-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Miért éri meg -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Miért éri meg drónt használni kereséshez?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {[
          { title: 'Gyorsaság', desc: 'Percek alatt a helyszín fölött vagyunk, akár több hektáros területet átvizsgálva.' },
          { title: 'Költséghatékonyság', desc: 'Kisebb létszámú csapat is hatékonyan dolgozhat, kevesebb erőforrással.' },
          { title: 'Biztonság', desc: 'Veszélyes vagy nehezen megközelíthető helyszínekre nem kell embert küldeni.' },
          { title: 'Dokumentálás', desc: 'Élő videó és képek segítik a további mentési vagy vizsgálati munkát.' },
        ].map((item) => (
          <div class="flex gap-4 p-6 bg-white rounded-2xl shadow-sm">
            <svg class="w-6 h-6 text-accent mt-1 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <div>
              <h3 class="font-heading font-bold text-primary mb-1">{item.title}</h3>
              <p class="text-sm text-text-light">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Szolgáltatási terület -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mb-4">
        Szolgáltatási terület
      </h2>
      <p class="text-text-light text-lg mb-4">
        Drónos keresés, felderítés és mentés 24 órás szolgálat — <strong>Győr és 100 km környéke</strong>.
      </p>
      <p class="text-text-light mb-6">
        Egyeztetés alapján vállalunk bevetéseket az egész ország területén!
      </p>
      <p class="text-text-light text-sm mb-8">
        Tapasztalatunk van önkéntes mentőcsoportokkal, rendőrséggel és családtagokkal történő
        együttműködésben. Diszkréten, felelősségteljesen és szabályosan dolgozunk.
      </p>
      <div class="bg-red-50 border-2 border-red-200 rounded-2xl p-8">
        <p class="text-red-700 font-bold text-lg mb-2">Sürgős esetben NE VÁRJ — HÍVJ MINKET AZONNAL</p>
        <a href="tel:+36305696550" class="text-red-600 font-heading text-3xl font-bold hover:text-red-700 transition-colors">
          +36 30 569 6550
        </a>
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
