---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
  type="article"
>
  <article class="py-12 lg:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Breadcrumbs -->
      <nav class="text-sm text-text-light mb-6">
        <a href="/" class="hover:text-primary transition-colors">Főoldal</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-text">{post.data.title}</span>
      </nav>

      <!-- Hero image -->
      <div class="aspect-video rounded-2xl overflow-hidden mb-8">
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Meta -->
      <div class="flex items-center gap-3 mb-6">
        <span class="text-sm bg-primary/10 text-primary px-3 py-1 rounded-full font-medium">
          {post.data.category}
        </span>
        <time class="text-sm text-text-light" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="text-sm text-text-light">• {post.data.author}</span>
      </div>

      <!-- Title -->
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-8 leading-tight">
        {post.data.title}
      </h1>

      <!-- Content -->
      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-primary prose-a:text-accent hover:prose-a:text-accent-dark prose-strong:text-text">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-12 p-8 bg-surface rounded-2xl text-center">
        <h2 class="font-heading text-2xl font-bold text-primary mb-3">
          Érdekli a drónos felmérés?
        </h2>
        <p class="text-text-light mb-6">
          Kérjen ingyenes konzultációt és személyre szabott árajánlatot!
        </p>
        <a
          href="/kapcsolat"
          class="inline-block bg-accent hover:bg-accent-dark text-white font-bold py-3 px-8 rounded-lg transition-colors"
        >
          Kapcsolatfelvétel
        </a>
      </div>

      <!-- Back to blog -->
      <div class="mt-8 text-center">
        <a href="/blog" class="text-primary hover:text-accent transition-colors font-medium">
          ← Vissza a bloghoz
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
