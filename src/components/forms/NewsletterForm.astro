<form class="flex gap-2" action="https://formspree.io/f/your-newsletter-id" method="POST">
  <input
    type="email"
    name="email"
    required
    placeholder="Email címed"
    class="flex-1 px-4 py-2.5 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors text-sm"
  />
  <button
    type="submit"
    class="px-5 py-2.5 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg transition-colors text-sm shrink-0"
  >
    Feliratkozás
  </button>
</form>
