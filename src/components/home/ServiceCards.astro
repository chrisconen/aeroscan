---
import { services } from '@/data/services';

interface Props {
  city?: string;
}

const { city } = Astro.props;
---

<section class="py-16 lg:py-24 bg-surface">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">
        {city ? `Szolgáltatásaink ${city}` : 'Szolgáltatásaink'}
      </h2>
      <p class="text-text-light text-lg max-w-2xl mx-auto">
        {city
          ? `Professzionális drónos megoldások ${city} és környékén — épületfelmérés, keresés-mentés, járőrözés és légi felvételek.`
          : 'Professzionális drónos megoldások épületfelméréshez, keresés-mentéshez és felügyelethez.'}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <a
          href={service.href}
          class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
        >
          {service.image.endsWith('.svg') ? (
            <div class="aspect-square overflow-hidden bg-gray-50 flex items-center justify-center">
              <img
                src={service.image}
                alt={service.title}
                class="w-[100px] h-[100px] object-contain"
                loading="lazy"
              />
            </div>
          ) : (
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-5">
            <h3 class="font-heading font-bold text-lg text-primary mb-2 group-hover:text-accent transition-colors">
              {service.title}
            </h3>
            <p class="text-sm text-text-light leading-relaxed">
              {city ? service.cityDescription(city) : service.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
