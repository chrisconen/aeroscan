---
import { contactInfo } from '@/data/navigation';
---

<section class="py-16 lg:py-24 bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">
      Kérjen ingyenes árajánlatot!
    </h2>
    <p class="text-lg text-gray-300 mb-8 max-w-2xl mx-auto">
      Vegye fel velünk a kapcsolatot és kérjen személyre szabott árajánlatot projektjéhez.
      Ingyenes konzultáció, átlátható árazás, gyors válasz.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="/kapcsolat"
        class="bg-accent hover:bg-accent-dark text-white font-bold py-3 px-8 rounded-lg transition-colors text-lg"
      >
        Árajánlat kérés
      </a>
      <a
        href={`tel:${contactInfo.phone.replace(/\s/g, '')}`}
        class="border-2 border-white/30 hover:border-white text-white font-semibold py-3 px-8 rounded-lg transition-colors text-lg"
      >
        {contactInfo.phone}
      </a>
    </div>
  </div>
</section>
