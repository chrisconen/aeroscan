---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { contactInfo } from '@/data/navigation';

const phoneRaw = contactInfo.phone.replace(/\s/g, '');

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Elveszett kisállat keresése drónnal',
      description: '4K zoomkamerás drónnal keressük meg elveszett kutyádat vagy macskádat. Gyors bevetés, országos lefedettség, éjszakai keresés.',
      provider: {
        '@type': 'LocalBusiness',
        name: 'AeroScan',
        telephone: '+36305696550',
        email: 'info@aeroscan.hu',
        url: 'https://aeroscan.hu',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Lepke utca 9',
          addressLocality: 'Bodonhely',
          postalCode: '9134',
          addressCountry: 'HU',
        },
      },
      areaServed: {
        '@type': 'Country',
        name: 'Magyarország',
      },
      serviceType: 'Elveszett háziállat keresése drónnal',
    },
  ],
};

const faqItems = [
  {
    q: 'Hogyan talál meg egy drón egy elveszett kutyát?',
    a: 'A DJI Mavic 2 Enterprise Zoom drónunk 4K kamerával és erős optikai zoommal pásztázza a területet a magasból. A zoom segítségével messziről is felismerhető az állat, anélkül hogy megzavarnánk. A GPS pontos helyet ad a megtaláláskor.',
  },
  {
    q: 'Éjjel is kerestek?',
    a: 'Igen. A drónunkon erős reflektor (spotlight) van, amellyel éjszaka is hatékonyan átvilágítjuk a terepet. A 4K kamera a megvilágított területen élesen mutatja az állatot.',
  },
  {
    q: 'Mennyi idő alatt értek ki?',
    a: 'Győr és környékén jellemzően 30 percen belül a helyszínen vagyunk. Távolabbi helyszínekre egyeztetés alapján indulunk, de a cél mindig a lehető leggyorsabb bevetés.',
  },
  {
    q: 'Milyen területen működik a keresés?',
    a: 'Erdő, mező, szántó, árkok, vízpart, lakott terület széle — a drón mindenhol hatékony, ahol a terep nehezen járható vagy nagy kiterjedésű. A zoom segítségével a sűrű növényzet széleit, tisztásokat és rejtekhelyeket is átvizsgáljuk.',
  },
  {
    q: 'Mennyibe kerül?',
    a: 'Hívj, és telefonon azonnal, átláthatóan megmondjuk az árat. A költség a távolságtól és a keresés időtartamától függ — rejtett díj nincs.',
  },
];
---

<BaseLayout
  title="Elveszett kutya és macska keresése drónnal – országos | AeroScan"
  description="Elveszett a kutyád vagy macskád? 4K zoomkamerás drónnal keressük meg, a levegőből — gyorsan, országosan. Hívj: +36 30 569 6550."
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- Hős szekció -->
  <section class="bg-primary py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 text-white text-center">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight mb-6">
        Elveszett a kutyád vagy a macskád? Drónnal, a levegőből megkeressük.
      </h1>
      <p class="text-lg md:text-xl text-gray-200 mb-8 max-w-3xl mx-auto">
        4K zoomkamerás drónnal a magasból fésüljük át a környéket — ott is,
        ahol gyalog órákig tartana. Gyors bevetés, országos lefedettség.
      </p>
      <a
        href={`tel:${phoneRaw}`}
        class="inline-flex items-center gap-3 bg-red-600 hover:bg-red-700 text-white font-bold py-4 px-10 rounded-xl transition-colors text-xl md:text-2xl shadow-lg focus:outline-2 focus:outline-offset-2 focus:outline-white"
      >
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Hívj most: {contactInfo.phone}
      </a>
      <p class="mt-4 text-red-300 font-semibold text-lg">
        Minden perc számít. Hívj, és indulunk.
      </p>
    </div>
  </section>

  <!-- Hogyan zajlik — 3 lépés -->
  <section class="py-16 lg:py-24">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Hogyan zajlik a keresés?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            step: '1',
            title: 'Felhívsz minket',
            desc: 'Elmondod, hol és mikor tűnt el a kisállatod. Azonnal egyeztetünk és indulunk.',
          },
          {
            step: '2',
            title: 'Drón a levegőben',
            desc: '4K kamerával és erős zoommal átfésüljük a területet — akár éjjel, reflektorral is.',
          },
          {
            step: '3',
            title: 'Élő keresés',
            desc: 'Élő képen keressük az állatodat. Ha megvan, pontos GPS-helyet adunk, hogy odaérj.',
          },
        ].map((item) => (
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-accent text-white rounded-full flex items-center justify-center font-heading text-2xl font-bold">
              {item.step}
            </div>
            <h3 class="font-heading font-bold text-lg text-primary mb-2">{item.title}</h3>
            <p class="text-text-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Miért hatékony a drón -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Miért hatékony a drónos kisállatkeresés?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {
            title: 'Hatalmas területet fed le percek alatt',
            desc: 'Erdő, mező, árkok, sűrű aljnövényzet — a drón felülről fésüli át, amit gyalog órákig tartana bejárni.',
          },
          {
            title: 'Erős zoom — messziről felismerhető az állat',
            desc: 'A DJI Mavic 2 Enterprise Zoom optikai és digitális zoomjával messziről, zavarás nélkül azonosítjuk az állatot — akár bokrok szélén, árokban vagy tisztáson.',
          },
          {
            title: 'Éjszakai keresés reflektorral',
            desc: 'Erős spotlight megvilágítással éjjel is átfésüljük a terepet. A 4K kamera a megvilágított területen élesen mutat minden mozgást.',
          },
          {
            title: 'Kevesebb stressz az állatnak',
            desc: 'Nincs nagy csoport, taposás, idegen szag — a drón a magasból, csendesen figyel, nem riasztja el az állatot.',
          },
        ].map((item) => (
          <div class="flex gap-4 p-6 bg-white rounded-2xl shadow-sm">
            <svg class="w-6 h-6 text-accent mt-1 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <div>
              <h3 class="font-heading font-bold text-primary mb-1">{item.title}</h3>
              <p class="text-sm text-text-light">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Őszinte elvárás-kezelés -->
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-6">
        Mire számíthatsz?
      </h2>
      <p class="text-lg text-text-light leading-relaxed">
        Nem ígérünk csodát, de a levegőből sokszorosára nő az esély — és
        <strong class="text-primary"> minél hamarabb hívsz, annál jobb</strong>.
        A drónos keresés nem helyettesíti a gyalogos keresést, hanem kiegészíti:
        a nehezen bejárható, nagy területeket a levegőből sokkal gyorsabban és
        hatékonyabban tudjuk átvizsgálni.
      </p>
    </div>
  </section>

  <!-- Országos lefedettség -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">
        Országos lefedettség — kimegyünk hozzád
      </h2>
      <p class="text-text-light text-lg mb-8">
        Drónos kisállatkeresés az egész ország területén. Aktív térségeink:
      </p>
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        {[
          { name: 'Győr', href: '/gyor' },
          { name: 'Szeged', href: '/szeged' },
          { name: 'Budapest', href: '/budapest' },
          { name: 'Pécs', href: '/pecs' },
          { name: 'Ajka és környéke', href: null },
          { name: 'Debrecen', href: '/debrecen' },
          { name: 'Sopron', href: '/sopron' },
          { name: 'Tatabánya', href: '/tatabanya' },
          { name: 'Dunaújváros', href: '/dunaujvaros' },
        ].map((city) =>
          city.href ? (
            <a href={city.href} class="bg-white border border-gray-200 rounded-full px-5 py-2 font-semibold text-primary hover:border-accent hover:text-accent transition-colors">
              {city.name}
            </a>
          ) : (
            <span class="bg-white border border-gray-200 rounded-full px-5 py-2 font-semibold text-primary">
              {city.name}
            </span>
          )
        )}
      </div>
      <p class="text-text-light">
        Nem találod a te térségedet? <strong>Hívj, és megbeszéljük</strong> — az ország bármely pontjára ki tudunk menni.
      </p>
    </div>
  </section>

  <!-- Ár -->
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-6">
        Mennyibe kerül?
      </h2>
      <p class="text-text-light text-lg mb-6">
        Átlátható árazás, rejtett költség nélkül.
      </p>
      <!-- TODO: Tényleges árak beírása — kiszállási díj, óradíj, csomagárak.
           Amíg nincs véglegesítve, a telefonos tájékoztatás marad. -->
      <div class="bg-surface rounded-2xl p-8">
        <p class="text-lg text-text mb-4">
          Hívj, és telefonon azonnal, átláthatóan megmondjuk az árat.
        </p>
        <p class="text-sm text-text-light mb-6">
          A költség a távolságtól és a keresés időtartamától függ.
          Telefonon a konkrét helyzeted alapján pontos tájékoztatást adunk.
        </p>
        <a
          href={`tel:${phoneRaw}`}
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold py-3 px-8 rounded-lg transition-colors text-lg focus:outline-2 focus:outline-offset-2 focus:outline-accent"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {contactInfo.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- GYIK -->
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Gyakran ismételt kérdések
      </h2>
      <div class="space-y-4">
        {faqItems.map((item) => (
          <details class="group bg-surface rounded-2xl">
            <summary class="cursor-pointer list-none flex items-center justify-between p-6 font-heading font-bold text-primary">
              {item.q}
              <svg class="w-5 h-5 shrink-0 text-text-light transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-text-light leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- A pilóta -->
  <section class="py-16 lg:py-24 bg-surface">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-8">
        Ki keres?
      </h2>
      <div class="flex flex-col sm:flex-row items-center gap-8 bg-white rounded-2xl p-8 shadow-sm">
        <div class="w-40 h-40 shrink-0 rounded-full overflow-hidden bg-gray-200 ring-4 ring-white shadow-lg">
          <img
            src="/images/kereso-mento-dron-pilota.webp"
            alt="Chris Conen drónpilóta"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <h3 class="font-heading font-bold text-xl text-primary mb-1">Chris Conen</h3>
          <p class="text-accent font-semibold text-sm mb-3">Drónpilóta</p>
          <p class="text-text-light leading-relaxed mb-3">
            Osztrák drónvezetői engedéllyel rendelkező, bejegyzett drónos szolgáltató.
            Személyesen megyek ki minden bevetésre — egyetlen, elérhető ember, akit közvetlenül hívsz.
          </p>
          <!-- TODO: Chris, írd ide a saját mondatodat, pl.: "Azért csinálom, mert..." -->
        </div>
      </div>
    </div>
  </section>

  <!-- Alsó CTA -->
  <section class="py-16 lg:py-24 bg-primary text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">
        Elveszett a kisállatod? Ne várj — hívj most!
      </h2>
      <p class="text-lg text-gray-300 mb-8 max-w-2xl mx-auto">
        Minél hamarabb indulunk, annál nagyobb az esély a megtalálásra.
      </p>
      <a
        href={`tel:${phoneRaw}`}
        class="inline-flex items-center gap-3 bg-red-600 hover:bg-red-700 text-white font-bold py-4 px-10 rounded-xl transition-colors text-xl shadow-lg focus:outline-2 focus:outline-offset-2 focus:outline-white"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {contactInfo.phone}
      </a>
    </div>
  </section>
</BaseLayout>
