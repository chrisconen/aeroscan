---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { contactInfo } from '@/data/navigation';
---

<BaseLayout
  title="Kapcsolat"
  description="Vegye fel velünk a kapcsolatot és kérjen személyre szabott árajánlatot! Ingyenes konzultáció, átlátható árazás, gyors visszajelzés."
>
  <!-- Hero -->
  <section class="bg-primary py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 text-center text-white">
      <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">
        Kapcsolatfelvétel / Árajánlatkérés
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Vegye fel velünk a kapcsolatot, és kérjen személyre szabott árajánlatot!
      </p>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Miért érdemes -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
        {[
          { icon: '💬', text: 'Ingyenes konzultáció az igények pontosítására' },
          { icon: '📋', text: 'Személyre szabott, átlátható árajánlat' },
          { icon: '⚡', text: 'Gyors visszajelzés, rugalmas időpont-egyeztetés' },
          { icon: '👥', text: 'Professzionális, tapasztalt csapat támogatása' },
        ].map((item) => (
          <div class="flex items-start gap-3 p-4 bg-surface rounded-xl">
            <span class="text-2xl shrink-0" aria-hidden="true">{item.icon}</span>
            <span class="text-sm text-text">{item.text}</span>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3">
          <h2 class="font-heading text-2xl font-bold text-primary mb-6">Kapcsolat űrlap</h2>
          <form action="https://formspree.io/f/xlgagrrd" method="POST" class="space-y-6" id="contact-form">
            <!-- Személyes adatok -->
            <fieldset>
              <legend class="font-heading font-bold text-primary mb-4">Az Ön adatai</legend>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="lastname" class="block text-sm font-medium text-text mb-1">Vezetéknév *</label>
                  <input type="text" id="lastname" name="lastname" required
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                    placeholder="Vezetéknév" />
                </div>
                <div>
                  <label for="firstname" class="block text-sm font-medium text-text mb-1">Keresztnév *</label>
                  <input type="text" id="firstname" name="firstname" required
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                    placeholder="Keresztnév" />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                <div>
                  <label for="street" class="block text-sm font-medium text-text mb-1">Utca, házszám</label>
                  <input type="text" id="street" name="street"
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                    placeholder="Utca, házszám" />
                </div>
                <div>
                  <label for="city" class="block text-sm font-medium text-text mb-1">Város</label>
                  <input type="text" id="city" name="city"
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                    placeholder="Város" />
                </div>
              </div>
              <div class="w-1/2 sm:w-1/4 mt-4">
                <label for="zip" class="block text-sm font-medium text-text mb-1">Irányítószám</label>
                <input type="text" id="zip" name="zip"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                  placeholder="Irányítószám" />
              </div>
            </fieldset>

            <!-- Elérhetőség -->
            <fieldset>
              <legend class="font-heading font-bold text-primary mb-4">Hogy érjük el Önt?</legend>
              <div class="mb-4">
                <p class="text-sm font-medium text-text mb-2">Előnyben részesített kapcsolati forma *</p>
                <div class="flex gap-6">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="preferred_contact" value="email" required
                      class="w-4 h-4 text-accent focus:ring-accent" />
                    <span class="text-sm">Email</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="preferred_contact" value="telefon"
                      class="w-4 h-4 text-accent focus:ring-accent" />
                    <span class="text-sm">Telefon</span>
                  </label>
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="email" class="block text-sm font-medium text-text mb-1">Email cím *</label>
                  <input type="email" id="email" name="email" required
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                    placeholder="pelda@email.hu" />
                </div>
                <div>
                  <label for="email_confirm" class="block text-sm font-medium text-text mb-1">Email cím visszaigazolása *</label>
                  <input type="email" id="email_confirm" name="email_confirm" required
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                    placeholder="pelda@email.hu" />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                <div>
                  <label for="phone" class="block text-sm font-medium text-text mb-1">Telefonszám *</label>
                  <input type="tel" id="phone" name="phone" required
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors"
                    placeholder="+36 30 123 4567" />
                </div>
                <div>
                  <label for="call_time" class="block text-sm font-medium text-text mb-1">Mikor hívjuk Önt? *</label>
                  <select id="call_time" name="call_time" required
                    class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors bg-white">
                    <option value="">Válasszon időpontot...</option>
                    <option value="9:00">9:00</option>
                    <option value="10:00">10:00</option>
                    <option value="11:00">11:00</option>
                    <option value="13:00">13:00</option>
                    <option value="14:00">14:00</option>
                    <option value="15:00">15:00</option>
                    <option value="16:00">16:00</option>
                    <option value="17:00">17:00</option>
                    <option value="18:00">18:00</option>
                  </select>
                </div>
              </div>
            </fieldset>

            <!-- Üzenet -->
            <fieldset>
              <legend class="font-heading font-bold text-primary mb-4">Üzenet</legend>
              <div>
                <label for="message" class="block text-sm font-medium text-text mb-1">Projekt leírása *</label>
                <textarea id="message" name="message" rows="5" required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors resize-y"
                  placeholder="Kérjük, írja le néhány mondatban a projektet!"></textarea>
              </div>
            </fieldset>

            <!-- GDPR -->
            <div class="flex items-start gap-3">
              <input type="checkbox" id="gdpr" name="gdpr" required
                class="w-4 h-4 mt-1 text-accent focus:ring-accent rounded" />
              <label for="gdpr" class="text-xs text-text-light">
                Elfogadom az <a href="/adatvedelmi-nyilatkozat" class="text-accent hover:text-accent-dark underline">adatvédelmi nyilatkozatot</a>,
                és hozzájárulok adataim kezeléséhez az ajánlatkérés feldolgozása céljából. *
              </label>
            </div>

            <button type="submit"
              class="w-full sm:w-auto bg-accent hover:bg-accent-dark text-white font-bold py-3 px-10 rounded-lg transition-colors text-lg">
              Üzenet küldése
            </button>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Contact info -->
          <div class="bg-surface rounded-2xl p-6">
            <h3 class="font-heading font-bold text-lg text-primary mb-4">Elérhetőségeink</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-text">Email</p>
                  <a href={`mailto:${contactInfo.email}`} class="text-sm text-accent hover:text-accent-dark">{contactInfo.email}</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-text">Telefon</p>
                  <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="text-sm text-accent hover:text-accent-dark">{contactInfo.phone}</a>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="text-sm font-medium text-text">Cím</p>
                  <p class="text-sm text-text-light">{contactInfo.address}</p>
                  <p class="text-sm text-text-light">{contactInfo.county}</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Map placeholder -->
          <div class="bg-surface rounded-2xl p-6">
            <h3 class="font-heading font-bold text-lg text-primary mb-4">Térképen</h3>
            <div class="aspect-video rounded-xl overflow-hidden bg-gray-200">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2686.5!2d17.2!3d47.6!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDfCsDM2JzAwLjAiTiAxN8KwMTInMDAuMCJF!5e0!3m2!1shu!2shu!4v1"
                class="w-full h-full border-0"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="AeroScan helyszín térképen"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const email = document.getElementById('email') as HTMLInputElement;
  const emailConfirm = document.getElementById('email_confirm') as HTMLInputElement;

  form?.addEventListener('submit', (e) => {
    if (email.value !== emailConfirm.value) {
      e.preventDefault();
      emailConfirm.setCustomValidity('Az email címek nem egyeznek!');
      emailConfirm.reportValidity();
    }
  });

  emailConfirm?.addEventListener('input', () => {
    emailConfirm.setCustomValidity('');
  });
</script>
