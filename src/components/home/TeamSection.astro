---
import { pilot } from '@/data/team';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section class="py-16 lg:py-24 bg-surface">
  <div class="max-w-7xl mx-auto px-4">
    <!-- A pilóta -->
    <div class="max-w-3xl mx-auto mb-16">
      <div class="text-center mb-8">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">
          A pilóta
        </h2>
        <p class="text-text-light text-lg">
          Egyetlen, elérhető, valódi ember — aki személyesen megy ki és keres.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-8 bg-white rounded-2xl p-8 shadow-sm">
        <div class="w-80 h-80 shrink-0 rounded-full overflow-hidden bg-gray-200 ring-6 ring-white shadow-lg">
          <img
            src={pilot.image}
            alt={pilot.name}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <h3 class="font-heading font-bold text-xl text-primary mb-1">{pilot.name}</h3>
          <p class="text-accent font-semibold text-sm mb-3">{pilot.role}</p>
          <p class="text-text-light leading-relaxed mb-3">
            Osztrák drónvezetői engedéllyel rendelkező, bejegyzett drónos fotó- és videószolgáltató.
            Számlaképes vállalkozás, teljes biztosítással.
          </p>
          <!-- TODO: Chris, írd ide a saját, személyes mondatodat arról, miért csinálod ezt.
               Pl.: "Azért keresek elveszett állatokat drónnal, mert..." -->
          <p class="text-text-light text-sm italic">
            „Én is kutyás vagyok, tudom milyen érzés, amikor elveszik egy kedvenc. Ezért csinálom, hogy segítsek megtalálni őket."
          </p>
        </div>
      </div>
    </div>

    <!-- Blog ajánló -->
    <div>
      <div class="text-center mb-8">
        <h3 class="font-heading text-2xl md:text-3xl font-bold text-primary mb-2">
          Legújabb blog bejegyzéseink
        </h3>
        <p class="text-text-light">Szakmai cikkek a dróntechnológia világából</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300">
            <div class="aspect-video overflow-hidden">
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">
                  {post.data.category}
                </span>
                <time class="text-xs text-text-light" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('hu-HU', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h4 class="font-heading font-bold text-primary group-hover:text-accent transition-colors line-clamp-2">
                {post.data.title}
              </h4>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/blog" class="inline-block border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold py-2 px-6 rounded-lg transition-colors">
          Összes bejegyzés
        </a>
      </div>
    </div>
  </div>
</section>
