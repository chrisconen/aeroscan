---
import { mainNav } from '@/data/navigation';
---

<nav class="hidden lg:flex items-center gap-1">
  {mainNav.map((item) => (
    'children' in item ? (
      <div class="relative group">
        <button class="px-3 py-2 text-text hover:text-primary font-medium rounded-lg hover:bg-gray-50 transition-colors flex items-center gap-1">
          {item.label}
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-white rounded-xl shadow-lg border border-gray-100 py-2 min-w-[200px]">
            {item.children.map((child) => (
              <a
                href={child.href}
                class="block px-4 py-2 text-sm text-text-light hover:text-primary hover:bg-gray-50 transition-colors"
              >
                {child.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    ) : (
      <a
        href={item.href}
        class="px-3 py-2 text-text hover:text-primary font-medium rounded-lg hover:bg-gray-50 transition-colors"
      >
        {item.label}
      </a>
    )
  ))}

  <a
    href="/kapcsolat"
    class="ml-2 bg-accent hover:bg-accent-dark text-white font-semibold py-2 px-5 rounded-lg transition-colors"
  >
    Árajánlat
  </a>
</nav>
